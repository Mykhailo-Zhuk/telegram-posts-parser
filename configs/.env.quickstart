# 🔧 QUICKSTART .env FILE FOR TELEGRAM REVIEW
# Створити копію: cp .env.quickstart .env
# Потім заповнити своїми даними

# ============================================
# 🔑 TELEGRAM API CREDENTIALS (ОБОВ'ЯЗКОВО!)
# Отримати на https://my.telegram.org -> API development tools
# ============================================
TG_API_ID=12345678                    # ЗАМІНИТИ на свій API ID
TG_API_HASH=abcdef1234567890abcdef1234567890  # ЗАМІНИТИ на свій API Hash

# ============================================
# 🧠 OLLAMA CONFIGURATION (ВИБІР 1 АБО 2)
# ============================================

# ВАРІАНТ 1: Локальний Ollama (рекомендовано)
# 1. Встановити Ollama: https://ollama.ai
# 2. Завантажити модель: ollama pull qwen2.5:latest
# 3. Використовувати ці налаштування:
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen2.5:latest
# OLLAMA_API_KEY=  # Не потрібно для локального

# ВАРІАНТ 2: Хмарний Ollama з API ключем
# OLLAMA_API_KEY=16aac302973f45dd922623b53f394a58.Rmqhv1CYSa1i2gQv8YupO2mr
# OLLAMA_BASE_URL=https://api.ollama.ai/v1
# OLLAMA_MODEL=qwen3.5:cloud

# ============================================
# 📝 ІНШІ НАЛАШТУВАННЯ
# ============================================

# Telegram сесія буде збережена автоматично
# Фото будуть збережені у папці photos/
# Логи будуть у pipeline.log, scheduler.log

# ============================================
# 🚀 ШВИДКИЙ СТАРТ:
# ============================================
# 1. cp .env.quickstart .env
# 2. Відредагуй .env: заміни TG_API_ID та TG_API_HASH
# 3. python3 pipeline.py  # Тест
# 4. python3 scheduler.py  # Автоматизація

# ============================================
# ℹ️ ДОВІДКА:
# ============================================
# Помилка "API ID or Hash cannot be empty"?
# → Перевір чи .env файл існує та містить TG_API_ID/TG_API_HASH
# 
# Помилка підключення до Ollama?
# → Перевір чи Ollama запущено: ollama serve
# → Перевір чи модель завантажена: ollama list
#
# Детальні інструкції: TELEGRAM_SETUP_GUIDE.md